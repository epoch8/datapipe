# Local datapipe-ml test services (see tests/docker-compose.yml).
# Optional for Sky/Vast integration tests: VAPI_API_KEY=...

TEST_DB_ENV=sqlite

# CPU-only training in CI and local pytest (see datapipe_ml.training.accelerator).
CUDA_VISIBLE_DEVICES=
NVIDIA_VISIBLE_DEVICES=

FIFTYONE_DATABASE_URI=mongodb://localhost:27017

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=datapipe-e2e
S3_PREFIX=datapipe-ml-tests/local
