DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/postgres

# Local mode: set LOCAL_IMAGES_DIR with images inside (optional LABELS_JSON)
# LOCAL_IMAGES_DIR=./data/images
# LABELS_JSON=./data/labels.json

# Zoo fallback: used when LOCAL_IMAGES_DIR is unset or dir missing/empty
ZOO_DATASET=caltech101
ZOO_LABEL_FIELD=ground_truth
ZOO_NUM_CLASSES=10

EMBEDDINGS_DIR=./data/embeddings
FIFTYONE_DATASET_NAME=datapipe_embedder_fiftyone
