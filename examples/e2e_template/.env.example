export AWS_ACCESS_KEY_ID=minioadmin
export AWS_SECRET_ACCESS_KEY=minioadmin
export AWS_REGION=us-east-1
export S3_ENDPOINT_URL=http://localhost:9000
export FSSPEC_S3_ENDPOINT_URL="${S3_ENDPOINT_URL}"
export S3_PUBLIC_URL=http://localhost:9000
export DATAPIPE_E2E_DIR=s3://datapipe-e2e
# Local cache for S3 working_dir artifacts and images downloaded for FiftyOne (mounted into compose fiftyone service)
export DATAPIPE_E2E_TMP_DIR=/tmp/datapipe-e2e

export LABEL_STUDIO_URL=http://localhost:8080
export LABEL_STUDIO_EMAIL=e2e@example.com
export LABEL_STUDIO_PASSWORD=qwerty123
export LABEL_STUDIO_API_KEY=replace-me
export LABEL_STUDIO_S3_ENDPOINT_URL=http://minio:9000
export DB_URL=postgresql+psycopg://postgres:password@localhost:5432/postgres
export DB_SCHEMA_DETECTION=datapipe_e2e_detection
export DB_SCHEMA_KEYPOINTS=datapipe_e2e_keypoints
export DB_SCHEMA_CLASSIFICATION=datapipe_e2e_classification
# Ops run logs in ClickHouse (docker-compose clickhouse service; see clickhouse/users.d/).
export CLICKHOUSE_RUN_LOGS_URL=clickhouse://default:@localhost:8123/default
export FIFTYONE_DATABASE_URI=mongodb://localhost:27017
